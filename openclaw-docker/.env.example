# OpenClaw Docker — example environment file.
# Copy this file to `.env` and customise before running `docker compose up`.
#
#   cp .env.example .env
#
# None of the values below are real secrets. Replace placeholders with values
# appropriate for your environment. Do NOT commit the resulting `.env` file.

# ---------------------------------------------------------------------------
# OpenClaw image
# ---------------------------------------------------------------------------
# The OpenClaw Docker image to run for every agent container. Replace this
# with the actual OpenClaw image reference you have access to (for example,
# a value pulled from the OpenClaw registry or a locally-built image).
OPENCLAW_IMAGE=your-openclaw-image:latest

# Image pull policy used by compose (always | missing | never).
OPENCLAW_PULL_POLICY=missing

# Restart policy applied to every agent container.
OPENCLAW_RESTART_POLICY=unless-stopped

# ---------------------------------------------------------------------------
# Shared settings
# ---------------------------------------------------------------------------
# Docker network name that all agents join. Compose creates it automatically.
OPENCLAW_NETWORK=openclaw-net

# Host-side directory that stores per-agent persistent state. Each agent gets
# its own subdirectory underneath this path.
OPENCLAW_DATA_DIR=./data

# Host-side directory that stores per-agent runtime configuration.
OPENCLAW_CONFIG_DIR=./config

# Timezone used inside every container.
OPENCLAW_TZ=UTC

# Log driver used for every agent container.
OPENCLAW_LOG_DRIVER=json-file
OPENCLAW_LOG_MAX_SIZE=10m
OPENCLAW_LOG_MAX_FILE=3

# ---------------------------------------------------------------------------
# API / secrets (placeholders — replace before running)
# ---------------------------------------------------------------------------
# Shared credentials used by every agent. Prefer per-agent overrides if
# different agents need different credentials.
OPENCLAW_API_KEY=replace-me-with-real-key
OPENCLAW_API_URL=https://api.openclaw.example.com

# ---------------------------------------------------------------------------
# Per-agent container names
# ---------------------------------------------------------------------------
ARCHITECT_CONTAINER_NAME=openclaw-architect
DESIGNER_CONTAINER_NAME=openclaw-designer
DEVELOPER_CONTAINER_NAME=openclaw-developer
QC_CONTAINER_NAME=openclaw-qc
OPERATOR_CONTAINER_NAME=openclaw-operator
PA_CONTAINER_NAME=openclaw-pa

# ---------------------------------------------------------------------------
# Per-agent published ports (host side). Pick free ports on your host.
# These are the ports your reverse proxy / browser connects to.
# Change `OPENCLAW_INTERNAL_PORT` if your image listens on a different port.
# ---------------------------------------------------------------------------
OPENCLAW_INTERNAL_PORT=8080

ARCHITECT_HOST_PORT=18001
DESIGNER_HOST_PORT=18002
DEVELOPER_HOST_PORT=18003
QC_HOST_PORT=18004
OPERATOR_HOST_PORT=18005
PA_HOST_PORT=18006

# ---------------------------------------------------------------------------
# Per-agent role identifiers (passed into the image as OPENCLAW_ROLE)
# ---------------------------------------------------------------------------
ARCHITECT_ROLE=architect
DESIGNER_ROLE=designer
DEVELOPER_ROLE=developer
QC_ROLE=qc
OPERATOR_ROLE=operator
PA_ROLE=pa
